{
  "name": "soracom-button",
  "version": "0.7.2",
  "description": "SORACOM LTE-M Button for Enterprise Simulator - Multi-platform application supporting Electron and React Native",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:electron",
    "build:core": "cd packages/core && npm run build",
    "build:electron": "cd packages/electron && npm run build",
    "start": "cd packages/electron && npm start",
    "start:mobile": "cd packages/mobile && npm start",
    "android": "cd packages/mobile && npm run android",
    "ios": "cd packages/mobile && npm run ios",
    "test": "npm run test:core && npm run test:electron",
    "test:core": "cd packages/core && npm test",
    "test:electron": "cd packages/electron && npm test",
    "test:mobile": "cd packages/mobile && npm test",
    "lint": "npm run lint:core && npm run lint:electron && npm run lint:mobile",
    "lint:core": "cd packages/core && npm run lint",
    "lint:electron": "cd packages/electron && npm run lint",
    "lint:mobile": "cd packages/mobile && npm run lint",
    "publish-mac": "cd packages/electron && npm run publish-mac",
    "publish-win64": "cd packages/electron && npm run publish-win64",
    "publish-win32": "cd packages/electron && npm run publish-win32",
    "build-mac": "cd packages/electron && npm run build-mac",
    "build-win64": "cd packages/electron && npm run build-win64",
    "build-win32": "cd packages/electron && npm run build-win32",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "author": "Kenichiro Kimura <kenichiro.kimura@gmail.com>",
  "license": "MIT",
  "build": {
    "asar": true,
    "asarUnpack": [
      "dist/libsoratun.*"
    ],
    "appId": "jp.soracom-ug.app.button",
    "files": [
      "package.json",
      "package-lock.json",
      "src",
      "dist"
    ],
    "publish": {
      "provider": "github",
      "owner": "kenichiro-kimura",
      "repo": "soracom-button",
      "releaseType": "draft",
      "publishAutoUpdate": false
    },
    "mac": {
      "target": "dmg",
      "icon": "img/icon.png",
      "category": "public.app-category.developer-tools",
      "notarize": true
    },
    "win": {
      "target": "nsis",
      "icon": "img/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-win-${arch}-${version}-setup.${ext}"
    }
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint --fix"
    ]
  }
}
